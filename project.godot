[layer_names]

3d_physics/layer_1="world"
3d_physics/layer_2="player"
3d_physics/layer_3="climbable"
3d_physics/layer_4="carryable"
3d_physics/layer_5="interactable"
3d_physics/layer_6="water"
3d_physics/layer_7="fire"
3d_physics/layer_8="heat"
3d_physics/layer_9="drowned"
3d_physics/layer_10="sound"
3d_physics/layer_11="flammable"
3d_physics/layer_12="updraft"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
occlusion_culling/use_occlusion_culling=true
